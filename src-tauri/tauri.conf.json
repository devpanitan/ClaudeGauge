{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClaudeGauge",
  "version": "0.1.0",
  "identifier": "dev.claudegauge.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ClaudeGauge",
        "width": 230,
        "height": 90,
        "minWidth": 150,
        "minHeight": 50,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": false,
        "center": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "publisher": "ClaudeGauge contributors",
    "shortDescription": "Claude Code token usage widget",
    "longDescription": "Floating always-on-top desktop widget that shows Claude Code token usage for the current 5-hour window. Reads local usage via ccusage. Not an official Anthropic tool.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
